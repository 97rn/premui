				BarFill.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
				BarFill.Parent = BarBg

				local BarFillCorner = Instance.new("UICorner")
				BarFillCorner.CornerRadius = UDim.new(1, 0)
				BarFillCorner.Parent = BarFill

				local sliding = false

				local function SetSlider(value)
					value = math.clamp(value, min, max)
					currentValue = value

					local percent = (value - min) / (max - min)
					ValText.Text = tostring(value)
					Tween(BarFill, {Size = UDim2.new(percent, 0, 1, 0)}, 0.08)

					if callback then
						callback(value)
					end
				end

				local function UpdateFromInput(input)
					local relativeX = math.clamp(input.Position.X - BarBg.AbsolutePosition.X, 0, BarBg.AbsoluteSize.X)
					local percentage = relativeX / BarBg.AbsoluteSize.X
					local value = math.floor(min + ((max - min) * percentage) + 0.5)
					SetSlider(value)
				end

				SetSlider(currentValue)

				BarBg.InputBegan:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
						sliding = true
						UpdateFromInput(input)
					end
				end)

				UserInputService.InputEnded:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
						sliding = false
					end
				end)

				UserInputService.InputChanged:Connect(function(input)
					if sliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
						UpdateFromInput(input)
					end
				end)

				return {
					SetValue = function(_, value)
						SetSlider(value)
					end
				}
			end

			function Elements:Input(name, callback)
				local InpFrame = Instance.new("Frame")
				InpFrame.Size = UDim2.new(1, 0, 0, 35)
				InpFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
				InpFrame.Parent = SectionContainer

				local InpCorner = Instance.new("UICorner")
				InpCorner.CornerRadius = UDim.new(0, 4)
				InpCorner.Parent = InpFrame

				local InpText = Instance.new("TextLabel")
				InpText.Size = UDim2.new(0.5, 0, 1, 0)
				InpText.Position = UDim2.new(0, 10, 0, 0)
				InpText.BackgroundTransparency = 1
				InpText.Text = name
				InpText.TextColor3 = Color3.fromRGB(255, 255, 255)
				InpText.Font = Enum.Font.Gotham
				InpText.TextSize = 13
				InpText.TextXAlignment = Enum.TextXAlignment.Left
				InpText.Parent = InpFrame

				local TextBox = Instance.new("TextBox")
				TextBox.Size = UDim2.new(0.4, 0, 0.7, 0)
				TextBox.Position = UDim2.new(0.6, -10, 0.15, 0)
				TextBox.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
				TextBox.Text = ""
				TextBox.PlaceholderText = "Enter..."
				TextBox.TextColor3 = Color3.fromRGB(255, 255, 255)
				TextBox.PlaceholderColor3 = Color3.fromRGB(120, 120, 120)
				TextBox.Font = Enum.Font.Gotham
				TextBox.TextSize = 12
				TextBox.Parent = InpFrame

				local BoxCorner = Instance.new("UICorner")
				BoxCorner.CornerRadius = UDim.new(0, 4)
				BoxCorner.Parent = TextBox

				TextBox.FocusLost:Connect(function(enterPressed)
					if callback then
						callback(TextBox.Text, enterPressed)
					end
				end)

				return {
					SetText = function(_, txt)
						TextBox.Text = txt
					end
				}
			end

			function Elements:Dropdown(name, options, callback)
				local DropFrame = Instance.new("Frame")
				DropFrame.Size = UDim2.new(1, 0, 0, 35)
				DropFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
				DropFrame.ClipsDescendants = true
				DropFrame.Parent = SectionContainer

				local DropCorner = Instance.new("UICorner")
				DropCorner.CornerRadius = UDim.new(0, 4)
				DropCorner.Parent = DropFrame

				local DropBtn = Instance.new("TextButton")
				DropBtn.Size = UDim2.new(1, 0, 0, 35)
				DropBtn.BackgroundTransparency = 1
				DropBtn.Text = ""
				DropBtn.Parent = DropFrame

				local DropTitle = Instance.new("TextLabel")
				DropTitle.Size = UDim2.new(1, -20, 1, 0)
				DropTitle.Position = UDim2.new(0, 10, 0, 0)
				DropTitle.BackgroundTransparency = 1
				DropTitle.Text = name .. " : ..."
				DropTitle.TextColor3 = Color3.fromRGB(255, 255, 255)
				DropTitle.Font = Enum.Font.Gotham
				DropTitle.TextSize = 13
				DropTitle.TextXAlignment = Enum.TextXAlignment.Left
				DropTitle.Parent = DropBtn

				local OptionContainer = Instance.new("Frame")
				OptionContainer.Size = UDim2.new(1, 0, 1, -35)
				OptionContainer.Position = UDim2.new(0, 0, 0, 35)
				OptionContainer.BackgroundTransparency = 1
				OptionContainer.Parent = DropFrame

				local OptionLayout = Instance.new("UIListLayout")
				OptionLayout.SortOrder = Enum.SortOrder.LayoutOrder
				OptionLayout.Parent = OptionContainer

				local isOpen = false
				local selected = nil

				local function SetDropdown(opt)
					selected = opt
					DropTitle.Text = name .. " : " .. tostring(opt)
					isOpen = false
					Tween(DropFrame, {Size = UDim2.new(1, 0, 0, 35)}, 0.2)
					if callback then callback(opt) end
				end

				DropBtn.MouseButton1Click:Connect(function()
					isOpen = not isOpen
					local targetHeight = isOpen and (35 + (#options * 30)) or 35
					Tween(DropFrame, {Size = UDim2.new(1, 0, 0, targetHeight)}, 0.2)
				end)

				for _, opt in ipairs(options) do
					local OptBtn = Instance.new("TextButton")
					OptBtn.Size = UDim2.new(1, 0, 0, 30)
					OptBtn.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
					OptBtn.Text = opt
					OptBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
					OptBtn.Font = Enum.Font.Gotham
					OptBtn.TextSize = 12
					OptBtn.Parent = OptionContainer

					OptBtn.MouseButton1Click:Connect(function()
						SetDropdown(opt)
					end)
				end

				return {
					SetValue = function(_, value)
						SetDropdown(value)
					end
				}
			end

			function Elements:Keybind(name, defaultKey, callback, onChange)
				local currentKey = defaultKey or Enum.KeyCode.E
				local listening = false

				local BindFrame = Instance.new("TextButton")
				BindFrame.Size = UDim2.new(1, 0, 0, 35)
				BindFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
				BindFrame.Text = ""
				BindFrame.AutoButtonColor = false
				BindFrame.Parent = SectionContainer

				local BindCorner = Instance.new("UICorner")
				BindCorner.CornerRadius = UDim.new(0, 4)
				BindCorner.Parent = BindFrame

				local BindText = Instance.new("TextLabel")
				BindText.Size = UDim2.new(1, -80, 1, 0)
				BindText.Position = UDim2.new(0, 10, 0, 0)
				BindText.BackgroundTransparency = 1
				BindText.Text = name
				BindText.TextColor3 = Color3.fromRGB(255, 255, 255)
				BindText.Font = Enum.Font.Gotham
				BindText.TextSize = 13
				BindText.TextXAlignment = Enum.TextXAlignment.Left
				BindText.Parent = BindFrame

				local KeyBox = Instance.new("Frame")
				KeyBox.Size = UDim2.new(0, 55, 0, 22)
				KeyBox.Position = UDim2.new(1, -65, 0.5, -11)
				KeyBox.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
				KeyBox.Parent = BindFrame

				local KeyCorner = Instance.new("UICorner")
				KeyCorner.CornerRadius = UDim.new(0, 4)
				KeyCorner.Parent = KeyBox

				local KeyStroke = Instance.new("UIStroke")
				KeyStroke.Color = Color3.fromRGB(40, 40, 40)
				KeyStroke.Parent = KeyBox

				local KeyLabel = Instance.new("TextLabel")
				KeyLabel.Size = UDim2.new(1, 0, 1, 0)
				KeyLabel.BackgroundTransparency = 1
				KeyLabel.Text = currentKey.Name
				KeyLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
				KeyLabel.Font = Enum.Font.GothamBold
				KeyLabel.TextSize = 11
				KeyLabel.Parent = KeyBox

				BindFrame.MouseButton1Click:Connect(function()
					listening = true
					KeyLabel.Text = "..."
					Tween(KeyStroke, {Color = Color3.fromRGB(255, 255, 255)}, 0.15)
				end)

				UserInputService.InputBegan:Connect(function(input, gpe)
					if gpe then return end

					if listening and input.UserInputType == Enum.UserInputType.Keyboard then
						listening = false
						currentKey = input.KeyCode
						KeyLabel.Text = currentKey.Name
						Tween(KeyStroke, {Color = Color3.fromRGB(40, 40, 40)}, 0.15)
						if onChange then onChange(currentKey) end
					elseif not listening and input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == currentKey then
						Tween(KeyBox, {BackgroundColor3 = Color3.fromRGB(35, 35, 35)}, 0.08).Completed:Connect(function()
							Tween(KeyBox, {BackgroundColor3 = Color3.fromRGB(10, 10, 10)}, 0.12)
						end)
						if callback then callback() end
					end
				end)

				return {
					SetKey = function(_, key)
						currentKey = key
						KeyLabel.Text = key.Name
						if onChange then onChange(key) end
					end
				}
			end

			return Elements
		end

		return TabElements
	end

	local LoaderObj = nil

	if UIConfig.Loader then
		local LoaderGui = Instance.new("ScreenGui")
		LoaderGui.Name = "Loader_" .. tostring(math.random(1000000, 9999999))
		LoaderGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
		LoaderGui.Parent = GetContainer()

		local LoaderContainer = Instance.new("Frame")
		LoaderContainer.Size = UDim2.new(1, 0, 1, 0)
		LoaderContainer.BackgroundTransparency = 1
		LoaderContainer.Parent = LoaderGui

		local LeftFrame = Instance.new("Frame")
		LeftFrame.Size = UDim2.new(0.5, 0, 1, 0)
		LeftFrame.Position = UDim2.new(0, 0, 0, 0)
		LeftFrame.BackgroundColor3 = Color3.fromRGB(8, 8, 8)
		LeftFrame.BorderSizePixel = 0
		LeftFrame.Parent = LoaderContainer

		local RightFrame = Instance.new("Frame")
		RightFrame.Size = UDim2.new(0.5, 0, 1, 0)
		RightFrame.Position = UDim2.new(0.5, 0, 0, 0)
		RightFrame.BackgroundColor3 = Color3.fromRGB(8, 8, 8)
		RightFrame.BorderSizePixel = 0
		RightFrame.Parent = LoaderContainer

		local CenterText = Instance.new("TextLabel")
		CenterText.Size = UDim2.new(1, 0, 1, 0)
		CenterText.BackgroundTransparency = 1
		CenterText.Text = "Loading..."
		CenterText.TextColor3 = Color3.fromRGB(255, 255, 255)
		CenterText.Font = Enum.Font.GothamBold
		CenterText.TextSize = 30
		CenterText.ZIndex = 10
		CenterText.Parent = LoaderContainer

		LoaderObj = {}
		local ended = false

		function LoaderObj:Start()
			MainFrame.Visible = false
		end

		function LoaderObj:SetText(txt)
			if not ended then
				CenterText.Text = txt
			end
		end

		function LoaderObj:End()
			if ended then return end
			ended = true

			local fade = Tween(CenterText, {TextTransparency = 1}, 0.3)
			fade.Completed:Wait()

			Tween(LeftFrame, {Position = UDim2.new(-0.5, 0, 0, 0)}, 0.6)
			local slide = Tween(RightFrame, {Position = UDim2.new(1, 0, 0, 0)}, 0.6)

			slide.Completed:Wait()
			LoaderGui:Destroy()

			MainFrame.Size = UDim2.new(0, 500, 0, 300)
			MainFrame.Visible = true
			Tween(MainFrame, {Size = UDim2.new(0, 600, 0, 400)}, 0.4)
		end
	else
		MainFrame.Visible = true
	end

	return Window, LoaderObj
end

return Library
