		ContentText.TextSize = 12
		ContentText.TextXAlignment = Enum.TextXAlignment.Left
		ContentText.TextYAlignment = Enum.TextYAlignment.Top
		ContentText.TextWrapped = true
		ContentText.TextColor3 = Color3.fromRGB(200, 200, 200)
		ContentText.TextTransparency = 1
		ContentText.Text = content
		ContentText.Parent = Notif

		local textSize = TextService:GetTextSize(content, 12, Enum.Font.Gotham, Vector2.new(276, math.huge))
		local targetHeight = textSize.Y + 42
		ContentText.Size = UDim2.new(1, -24, 0, textSize.Y)

		Tween(Notif, {Size = UDim2.new(1, 0, 0, targetHeight), BackgroundTransparency = 0}, 0.25)
		Tween(NotifStroke, {Transparency = 0}, 0.25)
		Tween(TitleText, {TextTransparency = 0}, 0.25)
		Tween(ContentText, {TextTransparency = 0}, 0.25)

		task.delay(duration, function()
			if not Notif.Parent then return end
			Tween(Notif, {Size = UDim2.new(1, 0, 0, 0), BackgroundTransparency = 1}, 0.25)
			Tween(NotifStroke, {Transparency = 1}, 0.25)
			Tween(TitleText, {TextTransparency = 1}, 0.2)
			Tween(ContentText, {TextTransparency = 1}, 0.2)
			task.delay(0.3, function()
				if Notif.Parent then
					Notif:Destroy()
				end
			end)
		end)
	end

