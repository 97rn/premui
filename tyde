local Library = {}

local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local Players = game:GetService("Players")
local TextService = game:GetService("TextService")

-- [ Internal Utilities ] --
local function GetContainer()
	local success, result = pcall(function() return gethui() end)
	if success and result then return result end
	return game:GetService("CoreGui"):FindFirstChild("RobloxGui") or Players.LocalPlayer:WaitForChild("PlayerGui")
end

local function Tween(instance, properties, duration)
	local tweenInfo = TweenInfo.new(duration or 0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
	local tween = TweenService:Create(instance, tweenInfo, properties)
	tween:Play()
	return tween
end

-- [ Notification System ] --
function Library:Notify(config)
	local title = config.Title or "Notification"
	local content = config.Content or ""
	local duration = config.Time or 5

	local core = GetContainer()
	local NotifGui = core:FindFirstChild("AeroNotifications") or Instance.new("ScreenGui", core)
	NotifGui.Name = "AeroNotifications"
	
	local Holder = NotifGui:FindFirstChild("NotifHolder") or Instance.new("Frame", NotifGui)
	if Holder.Name ~= "NotifHolder" then
		Holder.Name = "NotifHolder"
		Holder.Size = UDim2.new(0, 300, 1, -20)
		Holder.Position = UDim2.new(1, -310, 0, 10)
		Holder.BackgroundTransparency = 1
		local layout = Instance.new("UIListLayout", Holder)
		layout.VerticalAlignment = Enum.VerticalAlignment.Bottom
		layout.Padding = UDim.new(0, 10)
	end

	local Notif = Instance.new("Frame", Holder)
	Notif.Size = UDim2.new(1, 0, 0, 0)
	Notif.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
	Notif.ClipsDescendants = true
	Instance.new("UICorner", Notif).CornerRadius = UDim.new(0, 8)
	Instance.new("UIStroke", Notif).Color = Color3.fromRGB(40, 40, 40)

	local tl = Instance.new("TextLabel", Notif)
	tl.Text = title:upper()
	tl.Font = Enum.Font.GothamBold
	tl.TextSize = 13
	tl.TextColor3 = Color3.fromRGB(255, 255, 255)
	tl.Position = UDim2.fromOffset(10, 8)
	tl.BackgroundTransparency = 1

	local cl = Instance.new("TextLabel", Notif)
	cl.Text = content
	cl.Font = Enum.Font.Gotham
	cl.TextSize = 12
	cl.TextColor3 = Color3.fromRGB(180, 180, 180)
	cl.Position = UDim2.fromOffset(10, 26)
	cl.Size = UDim2.new(1, -20, 0, 0)
	cl.TextWrapped = true
	cl.BackgroundTransparency = 1
	cl.TextXAlignment = Enum.TextXAlignment.Left

	local ts = TextService:GetTextSize(content, 12, Enum.Font.Gotham, Vector2.new(280, 1000))
	Tween(Notif, {Size = UDim2.new(1, 0, 0, ts.Y + 45)}, 0.4)
	
	task.delay(duration, function()
		Tween(Notif, {Size = UDim2.new(1, 0, 0, 0), BackgroundTransparency = 1}, 0.4).Completed:Connect(function() Notif:Destroy() end)
	end)
end

-- [ Library Core ] --
function Library:Create(config)
	local ScreenGui = Instance.new("ScreenGui", GetContainer())
	ScreenGui.Name = "Aurora_Main"
	ScreenGui.ResetOnSpawn = false

	local MainFrame = Instance.new("Frame", ScreenGui)
	MainFrame.Size = UDim2.new(0, 580, 0, 380)
	MainFrame.Position = UDim2.new(0.5, -290, 0.5, -190)
	MainFrame.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
	MainFrame.Visible = false
	Instance.new("UICorner", MainFrame)
	Instance.new("UIStroke", MainFrame).Color = Color3.fromRGB(35, 35, 35)

	-- TopBar
	local TopBar = Instance.new("Frame", MainFrame)
	TopBar.Size = UDim2.new(1, 0, 0, 40)
	TopBar.BackgroundTransparency = 1

	local Title = Instance.new("TextLabel", TopBar)
	Title.Text = config.Title or "Aurora"
	Title.Size = UDim2.new(1, -20, 1, 0)
	Title.Position = UDim2.fromOffset(15, 0)
	Title.TextColor3 = Color3.fromRGB(255, 255, 255)
	Title.Font = Enum.Font.GothamBold
	Title.TextXAlignment = "Left"
	Title.BackgroundTransparency = 1

	-- SideBar & Content
	local SideBar = Instance.new("Frame", MainFrame)
	SideBar.Position = UDim2.fromOffset(10, 50)
	SideBar.Size = UDim2.new(0, 150, 1, -60)
	SideBar.BackgroundTransparency = 1
	Instance.new("UIListLayout", SideBar).Padding = UDim.new(0, 5)

	local Container = Instance.new("Frame", MainFrame)
	Container.Position = UDim2.fromOffset(170, 50)
	Container.Size = UDim2.new(1, -180, 1, -60)
	Container.BackgroundTransparency = 1

	local Window = {}
	local LoaderObj = {}

	-- [ Loader Logic ] --
	if config.Segments.UI.Loader then
		local LoadGui = Instance.new("ScreenGui", GetContainer())
		local LFrame = Instance.new("Frame", LoadGui)
		LFrame.Size = UDim2.new(1, 0, 1, 0)
		LFrame.BackgroundColor3 = Color3.fromRGB(5, 5, 5)
		
		local LText = Instance.new("TextLabel", LFrame)
		LText.Size = UDim2.new(1, 0, 1, 0)
		LText.TextColor3 = Color3.fromRGB(255, 255, 255)
		LText.Font = Enum.Font.GothamBold
		LText.TextSize = 25
		LText.Text = "Starting..."
		LText.BackgroundTransparency = 1

		function LoaderObj:Start() LoadGui.Enabled = true end
		function LoaderObj:SetText(t) LText.Text = t end
		function LoaderObj:End()
			Tween(LFrame, {BackgroundTransparency = 1}, 0.5)
			Tween(LText, {TextTransparency = 1}, 0.5).Completed:Connect(function()
				LoadGui:Destroy()
				MainFrame.Visible = true
				Library:Notify({Title = "Success", Content = "Interface Loaded Successfully!", Time = 3})
			end)
		end
	end

	-- [ Tab & Component Logic ] --
	function Window:Tab(name, icon)
		local Page = Instance.new("ScrollingFrame", Container)
		Page.Size = UDim2.new(1, 0, 1, 0)
		Page.BackgroundTransparency = 1
		Page.Visible = false
		Page.ScrollBarThickness = 0
		Instance.new("UIListLayout", Page).Padding = UDim.new(0, 10)

		local tbtn = Instance.new("TextButton", SideBar)
		tbtn.Size = UDim2.new(1, 0, 0, 35)
		tbtn.Text = "  " .. name
		tbtn.TextColor3 = Color3.fromRGB(150, 150, 150)
		tbtn.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
		tbtn.Font = Enum.Font.GothamSemibold
		tbtn.TextXAlignment = "Left"
		Instance.new("UICorner", tbtn)

		tbtn.MouseButton1Click:Connect(function()
			for _, p in pairs(Container:GetChildren()) do p.Visible = false end
			Page.Visible = true
		end)

		local Elements = {}
		function Elements:Section(stitle)
			local SecFrame = Instance.new("Frame", Page)
			SecFrame.Size = UDim2.new(1, -5, 0, 40) -- Auto-scales
			SecFrame.BackgroundTransparency = 1
			Instance.new("UIListLayout", SecFrame).Padding = UDim.new(0, 8)

			local slbl = Instance.new("TextLabel", SecFrame)
			slbl.Text = stitle:upper()
			slbl.TextColor3 = Color3.fromRGB(100, 100, 100)
			slbl.Font = Enum.Font.GothamBold
			slbl.TextSize = 12
			slbl.Size = UDim2.new(1, 0, 0, 20)
			slbl.BackgroundTransparency = 1
			slbl.TextXAlignment = "Left"

			local Comp = {}
			function Comp:Slider(n, min, max, def, callback)
				local sf = Instance.new("Frame", SecFrame)
				sf.Size = UDim2.new(1, 0, 0, 45)
				sf.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
				Instance.new("UICorner", sf)
				
				local lab = Instance.new("TextLabel", sf)
				lab.Text = n .. ": " .. def
				lab.Position = UDim2.fromOffset(10, 5)
				lab.TextColor3 = Color3.fromRGB(255, 255, 255)
				lab.BackgroundTransparency = 1

				-- Basic Slider Logic (Mobile Friendly)
				local bar = Instance.new("Frame", sf)
				bar.Size = UDim2.new(1, -20, 0, 4)
				bar.Position = UDim2.new(0, 10, 1, -10)
				bar.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
				
				local fill = Instance.new("Frame", bar)
				fill.Size = UDim2.fromScale((def-min)/(max-min), 1)
				fill.BackgroundColor3 = Color3.fromRGB(255, 255, 255)

				bar.InputBegan:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
						local move; move = UserInputService.InputChanged:Connect(function(i)
							if i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch then
								local p = math.clamp((i.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
								local val = math.floor(min + (max - min) * p)
								fill.Size = UDim2.fromScale(p, 1)
								lab.Text = n .. ": " .. val
								callback(val)
							end
						end)
						UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then move:Disconnect() end end)
					end
				end)
			end

			function Comp:Toggle(n, def, callback)
				local tf = Instance.new("TextButton", SecFrame)
				tf.Size = UDim2.new(1, 0, 0, 35)
				tf.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
				tf.Text = "  " .. n
				tf.TextColor3 = Color3.fromRGB(200, 200, 200)
				tf.TextXAlignment = "Left"
				Instance.new("UICorner", tf)
				
				local state = def
				local ind = Instance.new("Frame", tf)
				ind.Size = UDim2.new(0, 20, 0, 20)
				ind.Position = UDim2.new(1, -30, 0.5, -10)
				ind.BackgroundColor3 = state and Color3.fromRGB(0, 255, 100) or Color3.fromRGB(40, 40, 40)
				
				tf.MouseButton1Click:Connect(function()
					state = not state
					Tween(ind, {BackgroundColor3 = state and Color3.fromRGB(0, 255, 100) or Color3.fromRGB(40, 40, 40)}, 0.2)
					callback(state)
				end)
			end

			function Comp:Button(n, callback)
				local b = Instance.new("TextButton", SecFrame)
				b.Size = UDim2.new(1, 0, 0, 35)
				b.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
				b.Text = n
				b.TextColor3 = Color3.fromRGB(255, 255, 255)
				Instance.new("UICorner", b)
				b.MouseButton1Click:Connect(callback)
			end

			return Comp
		end
		return Elements
	end

	return Window, LoaderObj
end

-- [ EXECUTING YOUR SCRIPT ] --
local Window, Loader = Library:Create({
	Title = "Aurora",
	SubTitle = "Mobile",
	Version = "2.5",
	Segments = {
		UI = { Loader = true },
		Config = { AutoSave = true }
	}
})

