	SideBarPadding.PaddingLeft = UDim.new(0, 10)
	SideBarPadding.PaddingRight = UDim.new(0, 10)
	SideBarPadding.Parent = SideBar

	local PagesContainer = Instance.new("Frame")
	PagesContainer.Size = UDim2.new(1, -150, 1, 0)
	PagesContainer.Position = UDim2.new(0, 150, 0, 0)
	PagesContainer.BackgroundTransparency = 1
	PagesContainer.Parent = ContentContainer

	local minimized = false
	MinBtn.MouseButton1Click:Connect(function()
		minimized = not minimized
		if minimized then
			Tween(MainFrame, {Size = UDim2.new(0, 600, 0, 40)})
			ContentContainer.Visible = false
		else
			Tween(MainFrame, {Size = UDim2.new(0, 600, 0, 400)})
			task.wait(0.3)
			ContentContainer.Visible = true
		end
	end)

	CloseBtn.MouseButton1Click:Connect(function()
		local t = Tween(MainFrame, {Size = UDim2.new(0, 600, 0, 0)})
		t.Completed:Wait()
		ScreenGui:Destroy()
	end)

	local Window = {}
	local firstTab = true

	function Window:Tab(tabName)
		local TabBtn = Instance.new("TextButton")
		TabBtn.Size = UDim2.new(1, 0, 0, 30)
		TabBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
		TabBtn.Text = tabName
		TabBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
		TabBtn.Font = Enum.Font.GothamSemibold
		TabBtn.TextSize = 14
		TabBtn.Parent = SideBar

		local TabCorner = Instance.new("UICorner")
		TabCorner.CornerRadius = UDim.new(0, 6)
		TabCorner.Parent = TabBtn

		local Page = Instance.new("ScrollingFrame")
		Page.Size = UDim2.new(1, 0, 1, 0)
		Page.BackgroundTransparency = 1
		Page.ScrollBarThickness = 2
		Page.Visible = firstTab
		Page.Parent = PagesContainer

		local PageLayout = Instance.new("UIListLayout")
		PageLayout.SortOrder = Enum.SortOrder.LayoutOrder
		PageLayout.Padding = UDim.new(0, 10)
		PageLayout.Parent = Page

		local PagePadding = Instance.new("UIPadding")
		PagePadding.PaddingTop = UDim.new(0, 15)
		PagePadding.PaddingLeft = UDim.new(0, 15)
		PagePadding.PaddingRight = UDim.new(0, 15)
		PagePadding.PaddingBottom = UDim.new(0, 15)
		PagePadding.Parent = Page

		if firstTab then
			TabBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
			TabBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
			firstTab = false
		end

		TabBtn.MouseButton1Click:Connect(function()
			for _, child in ipairs(PagesContainer:GetChildren()) do
				if child:IsA("ScrollingFrame") then
					child.Visible = false
				end
			end
			for _, child in ipairs(SideBar:GetChildren()) do
				if child:IsA("TextButton") then
					Tween(child, {BackgroundColor3 = Color3.fromRGB(30, 30, 30)})
					Tween(child, {TextColor3 = Color3.fromRGB(200, 200, 200)})
				end
			end
			Page.Visible = true
			Tween(TabBtn, {BackgroundColor3 = Color3.fromRGB(45, 45, 45)})
			Tween(TabBtn, {TextColor3 = Color3.fromRGB(255, 255, 255)})
		end)

		local TabElements = {}

		function TabElements:Section(sectionName)
			local SectionContainer = Instance.new("Frame")
			SectionContainer.Size = UDim2.new(1, 0, 0, 0)
			SectionContainer.BackgroundTransparency = 1
			SectionContainer.Parent = Page

			local SectionLayout = Instance.new("UIListLayout")
			SectionLayout.SortOrder = Enum.SortOrder.LayoutOrder
			SectionLayout.Padding = UDim.new(0, 8)
			SectionLayout.Parent = SectionContainer

			local SectionTitle = Instance.new("TextLabel")
			SectionTitle.Size = UDim2.new(1, 0, 0, 20)
			SectionTitle.BackgroundTransparency = 1
			SectionTitle.Text = sectionName
			SectionTitle.TextColor3 = Color3.fromRGB(255, 255, 255)
			SectionTitle.TextSize = 14
			SectionTitle.Font = Enum.Font.GothamBold
			SectionTitle.TextXAlignment = Enum.TextXAlignment.Left
			SectionTitle.Parent = SectionContainer

			local Divider = Instance.new("Frame")
			Divider.Size = UDim2.new(1, 0, 0, 1)
			Divider.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
			Divider.BorderSizePixel = 0
			Divider.Parent = SectionContainer

			local Elements = {}

			local function UpdateSectionSize()
				local height = 0
				for _, child in ipairs(SectionContainer:GetChildren()) do
					if child:IsA("GuiObject") then
						height = height + child.AbsoluteSize.Y + SectionLayout.Padding.Offset
					end
				end
				SectionContainer.Size = UDim2.new(1, 0, 0, height)
				
				local pageHeight = 0
				for _, child in ipairs(Page:GetChildren()) do
					if child:IsA("GuiObject") then
						pageHeight = pageHeight + child.AbsoluteSize.Y + PageLayout.Padding.Offset
					end
				end
				Page.CanvasSize = UDim2.new(0, 0, 0, pageHeight + 30)
			end

			SectionContainer.ChildAdded:Connect(UpdateSectionSize)

			function Elements:Button(name, callback)
				local Btn = Instance.new("TextButton")
				Btn.Size = UDim2.new(1, 0, 0, 35)
				Btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
				Btn.Text = name
				Btn.TextColor3 = Color3.fromRGB(255, 255, 255)
				Btn.Font = Enum.Font.Gotham
				Btn.TextSize = 13
				Btn.Parent = SectionContainer

				local BtnCorner = Instance.new("UICorner")
				BtnCorner.CornerRadius = UDim.new(0, 4)
				BtnCorner.Parent = Btn

				Btn.MouseButton1Click:Connect(function()
					local t = Tween(Btn, {BackgroundColor3 = Color3.fromRGB(50, 50, 50)}, 0.1)
					t.Completed:Wait()
					Tween(Btn, {BackgroundColor3 = Color3.fromRGB(30, 30, 30)}, 0.1)
					callback()
				end)
				UpdateSectionSize()
			end

			function Elements:Toggle(name, default, callback)
				local state = default or false
				local TglFrame = Instance.new("TextButton")
				TglFrame.Size = UDim2.new(1, 0, 0, 35)
				TglFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
				TglFrame.Text = ""
				TglFrame.Parent = SectionContainer

				local TglCorner = Instance.new("UICorner")
				TglCorner.CornerRadius = UDim.new(0, 4)
				TglCorner.Parent = TglFrame

				local TglText = Instance.new("TextLabel")
				TglText.Size = UDim2.new(1, -50, 1, 0)
				TglText.Position = UDim2.new(0, 10, 0, 0)
				TglText.BackgroundTransparency = 1
				TglText.Text = name
				TglText.TextColor3 = Color3.fromRGB(255, 255, 255)
				TglText.Font = Enum.Font.Gotham
				TglText.TextSize = 13
				TglText.TextXAlignment = Enum.TextXAlignment.Left
				TglText.Parent = TglFrame

				local Indicator = Instance.new("Frame")
				Indicator.Size = UDim2.new(0, 20, 0, 20)
				Indicator.Position = UDim2.new(1, -30, 0.5, -10)
				Indicator.BackgroundColor3 = state and Color3.fromRGB(80, 200, 80) or Color3.fromRGB(60, 60, 60)
				Indicator.Parent = TglFrame

				local IndCorner = Instance.new("UICorner")
				IndCorner.CornerRadius = UDim.new(0, 4)
				IndCorner.Parent = Indicator

				TglFrame.MouseButton1Click:Connect(function()
					state = not state
					Tween(Indicator, {BackgroundColor3 = state and Color3.fromRGB(80, 200, 80) or Color3.fromRGB(60, 60, 60)}, 0.2)
					callback(state)
				end)
				UpdateSectionSize()
			end

			function Elements:Paragraph(text)
				local Para = Instance.new("TextLabel")
				Para.Size = UDim2.new(1, 0, 0, 0)
				Para.BackgroundTransparency = 1
				Para.Text = text
				Para.TextColor3 = Color3.fromRGB(180, 180, 180)
				Para.Font = Enum.Font.Gotham
				Para.TextSize = 13
				Para.TextWrapped = true
				Para.TextXAlignment = Enum.TextXAlignment.Left
				Para.Parent = SectionContainer
				
				Para.Size = UDim2.new(1, 0, 0, Para.TextBounds.Y + 10)
				UpdateSectionSize()
			end

			function Elements:Slider(name, min, max, default, callback)
				local SldFrame = Instance.new("Frame")
				SldFrame.Size = UDim2.new(1, 0, 0, 50)
				SldFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
				SldFrame.Parent = SectionContainer

				local SldCorner = Instance.new("UICorner")
				SldCorner.CornerRadius = UDim.new(0, 4)
				SldCorner.Parent = SldFrame

				local SldText = Instance.new("TextLabel")
				SldText.Size = UDim2.new(1, -20, 0, 25)
				SldText.Position = UDim2.new(0, 10, 0, 0)
				SldText.BackgroundTransparency = 1
				SldText.Text = name
				SldText.TextColor3 = Color3.fromRGB(255, 255, 255)
				SldText.Font = Enum.Font.Gotham
				SldText.TextSize = 13
				SldText.TextXAlignment = Enum.TextXAlignment.Left
				SldText.Parent = SldFrame

				local ValText = Instance.new("TextLabel")
				ValText.Size = UDim2.new(0, 50, 0, 25)
				ValText.Position = UDim2.new(1, -60, 0, 0)
				ValText.BackgroundTransparency = 1
				ValText.Text = tostring(default)
				ValText.TextColor3 = Color3.fromRGB(255, 255, 255)
				ValText.Font = Enum.Font.Gotham
				ValText.TextSize = 13
				ValText.TextXAlignment = Enum.TextXAlignment.Right
				ValText.Parent = SldFrame

				local BarBg = Instance.new("TextButton")
				BarBg.Size = UDim2.new(1, -20, 0, 6)
				BarBg.Position = UDim2.new(0, 10, 0, 32)
				BarBg.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
				BarBg.Text = ""
				BarBg.Parent = SldFrame

				local BarBgCorner = Instance.new("UICorner")
				BarBgCorner.CornerRadius = UDim.new(1, 0)
				BarBgCorner.Parent = BarBg

				local BarFill = Instance.new("Frame")
				local fillPercent = (default - min) / (max - min)
				BarFill.Size = UDim2.new(fillPercent, 0, 1, 0)
				BarFill.BackgroundColor3 = Color3.fromRGB(100, 150, 255)
				BarFill.Parent = BarBg

				local BarFillCorner = Instance.new("UICorner")
				BarFillCorner.CornerRadius = UDim.new(1, 0)
				BarFillCorner.Parent = BarFill

				local sliding = false

				local function updateSlider(input)
					local relativeX = math.clamp(input.Position.X - BarBg.AbsolutePosition.X, 0, BarBg.AbsoluteSize.X)
					local percentage = relativeX / BarBg.AbsoluteSize.X
					local value = math.floor(min + ((max - min) * percentage))
					ValText.Text = tostring(value)
					Tween(BarFill, {Size = UDim2.new(percentage, 0, 1, 0)}, 0.1)
					callback(value)
				end

				BarBg.InputBegan:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
						sliding = true
						updateSlider(input)
					end
				end)

				UserInputService.InputEnded:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
						sliding = false
					end
				end)

				UserInputService.InputChanged:Connect(function(input)
					if sliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
						updateSlider(input)
					end
				end)
				UpdateSectionSize()
			end

			function Elements:Input(name, callback)
				local InpFrame = Instance.new("Frame")
				InpFrame.Size = UDim2.new(1, 0, 0, 35)
				InpFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
				InpFrame.Parent = SectionContainer

				local InpCorner = Instance.new("UICorner")
				InpCorner.CornerRadius = UDim.new(0, 4)
				InpCorner.Parent = InpFrame

				local InpText = Instance.new("TextLabel")
				InpText.Size = UDim2.new(0.5, 0, 1, 0)
				InpText.Position = UDim2.new(0, 10, 0, 0)
				InpText.BackgroundTransparency = 1
				InpText.Text = name
				InpText.TextColor3 = Color3.fromRGB(255, 255, 255)
				InpText.Font = Enum.Font.Gotham
				InpText.TextSize = 13
				InpText.TextXAlignment = Enum.TextXAlignment.Left
				InpText.Parent = InpFrame

				local TextBox = Instance.new("TextBox")
				TextBox.Size = UDim2.new(0.4, 0, 0.7, 0)
				TextBox.Position = UDim2.new(0.6, -10, 0.15, 0)
				TextBox.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
				TextBox.Text = ""
				TextBox.TextColor3 = Color3.fromRGB(255, 255, 255)
				TextBox.Font = Enum.Font.Gotham
				TextBox.TextSize = 12
				TextBox.Parent = InpFrame

				local BoxCorner = Instance.new("UICorner")
				BoxCorner.CornerRadius = UDim.new(0, 4)
				BoxCorner.Parent = TextBox

				TextBox.FocusLost:Connect(function(enterPressed)
					callback(TextBox.Text)
				end)
				UpdateSectionSize()
			end

			function Elements:Dropdown(name, options, callback)
				local dropHeight = 35
				local DropFrame = Instance.new("Frame")
				DropFrame.Size = UDim2.new(1, 0, 0, dropHeight)
				DropFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
				DropFrame.ClipsDescendants = true
				DropFrame.Parent = SectionContainer

				local DropCorner = Instance.new("UICorner")
				DropCorner.CornerRadius = UDim.new(0, 4)
				DropCorner.Parent = DropFrame

				local DropBtn = Instance.new("TextButton")
				DropBtn.Size = UDim2.new(1, 0, 0, 35)
				DropBtn.BackgroundTransparency = 1
				DropBtn.Text = ""
				DropBtn.Parent = DropFrame

				local DropTitle = Instance.new("TextLabel")
				DropTitle.Size = UDim2.new(1, -20, 1, 0)
				DropTitle.Position = UDim2.new(0, 10, 0, 0)
				DropTitle.BackgroundTransparency = 1
				DropTitle.Text = name .. " : ..."
				DropTitle.TextColor3 = Color3.fromRGB(255, 255, 255)
				DropTitle.Font = Enum.Font.Gotham
				DropTitle.TextSize = 13
				DropTitle.TextXAlignment = Enum.TextXAlignment.Left
				DropTitle.Parent = DropBtn

				local OptionContainer = Instance.new("Frame")
				OptionContainer.Size = UDim2.new(1, 0, 1, -35)
				OptionContainer.Position = UDim2.new(0, 0, 0, 35)
				OptionContainer.BackgroundTransparency = 1
				OptionContainer.Parent = DropFrame

				local OptionLayout = Instance.new("UIListLayout")
				OptionLayout.SortOrder = Enum.SortOrder.LayoutOrder
				OptionLayout.Parent = OptionContainer

				local isOpen = false

				DropBtn.MouseButton1Click:Connect(function()
					isOpen = not isOpen
					local targetHeight = isOpen and (35 + (#options * 30)) or 35
					Tween(DropFrame, {Size = UDim2.new(1, 0, 0, targetHeight)}, 0.2).Completed:Connect(UpdateSectionSize)
				end)

				for _, opt in ipairs(options) do
					local OptBtn = Instance.new("TextButton")
					OptBtn.Size = UDim2.new(1, 0, 0, 30)
					OptBtn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
					OptBtn.Text = opt
					OptBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
					OptBtn.Font = Enum.Font.Gotham
					OptBtn.TextSize = 12
					OptBtn.Parent = OptionContainer

					OptBtn.MouseButton1Click:Connect(function()
						DropTitle.Text = name .. " : " .. opt
						isOpen = false
						Tween(DropFrame, {Size = UDim2.new(1, 0, 0, 35)}, 0.2).Completed:Connect(UpdateSectionSize)
						callback(opt)
					end)
				end
				UpdateSectionSize()
			end

			return Elements
		end

		return TabElements
	end

	local LoaderObj = nil

	if UIConfig.Loader then
		local LoaderGui = Instance.new("ScreenGui")
		LoaderGui.Name = tostring(math.random(1000000, 9999999))
		LoaderGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
		LoaderGui.Parent = GetContainer()

		local LoaderContainer = Instance.new("Frame")
		LoaderContainer.Size = UDim2.new(1, 0, 1, 0)
		LoaderContainer.BackgroundTransparency = 1
		LoaderContainer.Parent = LoaderGui

		local LeftFrame = Instance.new("Frame")
		LeftFrame.Size = UDim2.new(0.5, 0, 1, 0)
		LeftFrame.Position = UDim2.new(0, 0, 0, 0)
		LeftFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
		LeftFrame.BorderSizePixel = 0
		LeftFrame.Parent = LoaderContainer

		local RightFrame = Instance.new("Frame")
		RightFrame.Size = UDim2.new(0.5, 0, 1, 0)
		RightFrame.Position = UDim2.new(0.5, 0, 0, 0)
		RightFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
		RightFrame.BorderSizePixel = 0
		RightFrame.Parent = LoaderContainer

		local CenterText = Instance.new("TextLabel")
		CenterText.Size = UDim2.new(1, 0, 1, 0)
		CenterText.BackgroundTransparency = 1
		CenterText.Text = "Loading..."
		CenterText.TextColor3 = Color3.fromRGB(255, 255, 255)
		CenterText.Font = Enum.Font.GothamBold
		CenterText.TextSize = 30
		CenterText.ZIndex = 10
		CenterText.Parent = LoaderContainer

		LoaderObj = {}
		local ended = false

		function LoaderObj:Start()
			MainFrame.Visible = false
		end

		function LoaderObj:SetText(txt)
			if not ended then
				CenterText.Text = txt
			end
		end

		function LoaderObj:End()
			if ended then return end
			ended = true

			local fade = Tween(CenterText, {TextTransparency = 1}, 0.3)
			fade.Completed:Wait()

			Tween(LeftFrame, {Position = UDim2.new(-0.5, 0, 0, 0)}, 0.6)
			local slide = Tween(RightFrame, {Position = UDim2.new(1, 0, 0, 0)}, 0.6)
			
			slide.Completed:Wait()
			LoaderGui:Destroy()

			MainFrame.Size = UDim2.new(0, 500, 0, 300)
			MainFrame.Visible = true
			Tween(MainFrame, {Size = UDim2.new(0, 600, 0, 400)}, 0.4)
		end
	else
		MainFrame.Visible = true
	end

	return Window, LoaderObj
end

return Library
